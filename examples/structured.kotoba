(ns examples.structured)

(defn abs [x]
  (if (< x 0) (- x) x))

(defn score [x bonus]
  (let [m (* x 2)
        total (+ m bonus)]
    (abs total)))

(defn calc [x y]
  (+ (quot x y) (- x y)))

(defn relations [x y]
  (+ (if (= x y) 1 0)
     (if (> x y) 2 0)
     (if (<= x y) 4 0)
     (if (>= x y) 8 0)))

(defn main []
  (score -20 -2))
