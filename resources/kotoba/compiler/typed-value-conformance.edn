   :expect 10}
  {:id :heterogeneous-vector
   :source "(defn main [] (hetero-vector-at [:vector [:i64 :string :bool]] (hetero-vector [:vector [:i64 :string :bool]] 7 \"safe\" true) 0))"
   :expect 7}
  {:id :typed-set
