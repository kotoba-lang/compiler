{:kotoba.capability-kit/name :clock
 :kotoba.capability-kit/version 1
 :capability {:name :clock/now :id 7}
 :semantics {:domains {:wall {:unit :unix-milliseconds
                              :monotonic false}
                       :monotonic {:unit :nanoseconds
                                   :monotonic :nondecreasing-per-provider}}
             :source-authority :host
             :observation-sequence :provider-local
             :ambient-clock false
             :timer-handles false}
 :request [:variant :kotoba.clock/request [[:wall :bool] [:monotonic :bool]]]
 :result
 [:variant :kotoba.clock/result
  [[:wall [:record :kotoba.clock/wall
            [[:unix-millis :i64] [:observation-sequence :i64]]]]
   [:monotonic [:record :kotoba.clock/monotonic
                 [[:nanos :i64] [:observation-sequence :i64]]]]
   [:error [:record :kotoba.clock/error
             [[:code :keyword] [:message :string]]]]]]
 :qualification {:reference :implemented :wasm-aot :pending
                 :native-aot :pending :jit :pending}}
