{:kotoba.capability-kit/name :state
 :kotoba.capability-kit/version 1
 :capability {:name :state/transact :id 8}
 :semantics {:ownership :host
             :isolation :per-provider-instance
             :ordering :synchronous-linearized
             :ambient-access false
             :operations [:get :put :delete]}
 :limits {:entries 256 :key :bounded-keyword :value :bounded-string}
 :request
 [:variant :kotoba.state/request
  [[:get [:record :kotoba.state/get [[:key :keyword]]]]
   [:put [:record :kotoba.state/put [[:key :keyword] [:value :string]]]]
   [:delete [:record :kotoba.state/delete [[:key :keyword]]]]]]
 :result
 [:variant :kotoba.state/result
  [[:found [:record :kotoba.state/entry [[:key :keyword] [:value :string] [:version :i64]]]]
   [:missing :bool]
   [:written [:record :kotoba.state/entry [[:key :keyword] [:value :string] [:version :i64]]]]
   [:deleted :bool]
   [:error [:record :kotoba.state/error [[:code :keyword] [:message :string]]]]]]
 :qualification {:reference :implemented :wasm-aot :pending :native-aot :pending :jit :pending}}
