{:kotoba.capability-kit/name :llm
 :kotoba.capability-kit/version 1
 :capability {:name :llm/generate :id 11}
 :semantics {:operation :generate-text
             :model-authority :host-exact-keyword-allowlist
             :credentials :host-only
             :provider-sdk-objects false
             :streaming false
             :tool-calls false
             :execution :synchronous-reference}
 :limits {:system-bytes 65536 :prompt-bytes 65536 :output-bytes 65536
          :max-output-tokens [1 4096] :temperature-milli [0 2000]}
 :request
 [:record :kotoba.llm/generate-request
  [[:model :keyword] [:system :string] [:prompt :string]
   [:max-output-tokens :i64] [:temperature-milli :i64]]]
 :result
 [:variant :kotoba.llm/result
  [[:ok [:record :kotoba.llm/completion
          [[:text :string] [:finish-reason :keyword]
           [:usage [:record :kotoba.llm/usage
                    [[:input-tokens :i64] [:output-tokens :i64]]]]]]]
   [:error [:record :kotoba.llm/error
             [[:code :keyword] [:message :string] [:retryable :bool]]]]]]
 :qualification {:reference :implemented :wasm-aot :pending
                 :native-aot :pending :jit :pending}}
