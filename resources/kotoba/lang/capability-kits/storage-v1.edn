{:kotoba.capability-kit/name :storage
 :kotoba.capability-kit/version 1
 :capability {:name :storage/transact :id 12}
 :semantics {:ownership :host
             :namespace :host-fixed-per-provider
             :durability :transport-commit-before-result
             :concurrency :conditional-version
             :ambient-filesystem false
             :backend-handles false
             :operations [:get :put :delete]}
 :limits {:key :bounded-keyword :value-bytes 65536
          :namespace-quota :host-provider-required}
 :request
 [:variant :kotoba.storage/request
  [[:get [:record :kotoba.storage/get [[:key :keyword]]]]
   [:put [:record :kotoba.storage/put
          [[:key :keyword] [:value :string]
           [:expected-version [:option :i64]]]]]
   [:delete [:record :kotoba.storage/delete
             [[:key :keyword] [:expected-version [:option :i64]]]]]]]
 :result
 [:variant :kotoba.storage/result
  [[:found [:record :kotoba.storage/entry
             [[:key :keyword] [:value :string] [:version :i64]]]]
   [:missing :bool]
   [:written [:record :kotoba.storage/entry
               [[:key :keyword] [:value :string] [:version :i64]]]]
   [:deleted :bool]
   [:conflict [:record :kotoba.storage/conflict
                [[:key :keyword] [:current-version [:option :i64]]]]]
   [:error [:record :kotoba.storage/error
             [[:code :keyword] [:message :string] [:retryable :bool]]]]]]
 :qualification {:reference :implemented :wasm-aot :pending
                 :native-aot :pending :jit :pending}}
