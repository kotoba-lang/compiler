{:kotoba.capability-kit/name :log
 :kotoba.capability-kit/version 1
 :capabilities [{:name :log/read :id 5}
                {:name :log/append :id 6}]
 :semantics {:format :structured
             :sequence :provider-linearized
             :retention :bounded-oldest-drop-with-truncation-signal
             :sink-handles false
             :ambient-stdout false
             :read-scope :same-provider-instance}
 :limits {:fields-per-entry 4 :read-entries 8 :retained-entries 256
          :after-sequence :non-negative-i64
          :message :bounded-string :field-value :bounded-string}
 :field [:record :kotoba.log/field [[:key :keyword] [:value :string]]]
 :append
 {:request [:record :kotoba.log/append-request
            [[:level :keyword] [:event :keyword] [:message :string]
             [:fields [:set [:record :kotoba.log/field
                             [[:key :keyword] [:value :string]]]]]]]
  :result [:record :kotoba.log/append-result [[:sequence :i64]]]}
 :read
 {:request [:record :kotoba.log/read-request
            [[:after-sequence :i64] [:limit :i64]]]
  :result [:record :kotoba.log/read-result
           [[:oldest-sequence :i64] [:latest-sequence :i64] [:truncated :bool]
            [:entries
             [:set
              [:record :kotoba.log/entry
               [[:sequence :i64]
                [:level :keyword]
                [:event :keyword]
                [:message :string]
                [:fields
                 [:set
                  [:record :kotoba.log/field
                   [[:key :keyword] [:value :string]]]]]]]]]]]}
 :qualification {:reference :implemented :wasm-aot :pending
                 :native-aot :pending :jit :pending}}
