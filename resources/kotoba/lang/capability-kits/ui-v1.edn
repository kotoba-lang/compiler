{:kotoba.capability-kit/name :ui
 :kotoba.capability-kit/version 1
 :capabilities [{:name :ui/commit :id 9}
                {:name :ui/next-event :id 10}]
 :semantics {:render-model :declarative-flat-tree
             :host-object-access false
             :ordering :revision-linearized
             :event-delivery :bounded-pull
             :ambient-dom false}
 :limits {:nodes 32 :queued-events 64 :text :bounded-string}
 :node [:record :kotoba.ui/node
        [[:id :keyword] [:parent [:option :keyword]]
         [:kind :keyword] [:text :string]]]
 :commit {:request [:record :kotoba.ui/commit-request
                    [[:base-revision :i64]
                     [:nodes [:set [:record :kotoba.ui/node
                                    [[:id :keyword] [:parent [:option :keyword]]
                                     [:kind :keyword] [:text :string]]]]]]]
          :result [:record :kotoba.ui/commit-result
                   [[:revision :i64] [:node-count :i64]]]}
 :event {:request [:record :kotoba.ui/event-request [[:after-revision :i64]]]
         :result [:option [:record :kotoba.ui/event
                           [[:revision :i64] [:target :keyword]
                            [:kind :keyword] [:value :string]]]]}
 :qualification {:reference :implemented :wasm-aot :pending
                 :native-aot :pending :jit :pending}}
