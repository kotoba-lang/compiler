{:kotoba.application-language/format :v1
 :authority "The language specification and reference conformance vectors are normative; compiler availability is not language admission."
 :execution-order [:specified :reference-implemented :aot-qualified :jit-qualified]
 :surface
 {:grammar :kotoba.lang.guest-grammar/v1
  :schemas {:identity :qualified-keyword+closed-graph-sha256
            :limits {:schemas 32 :descriptor-depth 8 :descriptor-nodes 64}}
  :imports {:form :typed-capability
            :ambient-host-calls false
            :request-validation :before-provider
            :result-validation :after-provider}
  :exports {:functions :explicit-or-public :mutable-host-object-identity false}
  :effects {:admission :deny-by-default :declaration :closed-set}}
 :host
 {:registry :kotoba.provider-registry/v1
  :provider-keys [:request-type :result-type :invoke]
  :contract-match :exact
  :kits {:state {:version 1 :status :reference-implemented}
         :ui {:version 1 :status :reference-implemented}
         :http {:version 1 :status :reference-implemented}
         :llm {:version 1 :status :reference-implemented}
         :storage {:version 1 :status :reference-implemented}
         :clock {:version 1 :status :reference-implemented}
         :log {:version 1 :status :reference-implemented}}
  :lifecycle [:validate-request :invoke-provider :validate-result]
  :resource-model [:fuel :depth :nodes :bytes :provider-timeout]}
 :reference-runtime
 {:implementation :kotoba.compiler.reference-runtime/v1
  :platforms [:clj :cljs]
  :input :checked-kir
  :role :normative-executable-semantics}
 :provider-conformance
 {:manifest :kotoba.provider-conformance/v1
  :structural-qualification :required
  :semantic-kit-vectors :required}
 :component-model
 {:status :specified
  :contract :kotoba.component-model/v1
  :artifact-owner :kotoba-lang/compiler
  :target :wasm-component-kotoba-v1
  :wasi-baseline "0.3.0"
  :function-profiles [:sync :async-explicit]
  :world {:imports :declared-typed-capabilities-only
          :exports :declared-entry-points-only
          :undeclared-imports :reject}
  :wit-mapping {:i64 :s64 :f32 :f32 :f64 :f64 :bool :bool
                :string :string :keyword :bounded-string-newtype
                :option :option :result :result :record :record
                :variant :variant :vector :validated-list
                :set :validated-canonical-list
                :map :validated-canonical-entry-list
                :recursive-schema :reject-v1}
  :lowering-rule "Reject schemas whose bounds or identity cannot be preserved by generated WIT and the canonical ABI."
  :runtime-rule "No runtime-specific runner or private import adapter is normative."
  :wasi {:application-ambient-authority false
         :owner :provider-component
         :imports :capability-kit-declared-only
         :composition :closed-world}}
 :backend-qualification
 {:wasm-aot :conformance-required
  :native-aot :conformance-required
  :jit :conformance-required
  :provider-gate :kotoba.backend-provider-qualification/v1
  :rule "An unavailable backend is an implementation gap, not a reason to remove a specified safe language feature. Runtime-specific adapters do not qualify the Component Model backend."}}
