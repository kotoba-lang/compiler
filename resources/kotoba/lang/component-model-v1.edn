{:kotoba.component-model/format :v1
 :target :wasm-component-kotoba-v1
 :spec-baseline
 {:component-model {:source "https://github.com/WebAssembly/component-model"
                    :revision "e6bb1e456e946abd01173755468134d7c75c9f07"
                    :binary-preamble {:magic [0 97 115 109] :version [13 0] :layer [1 0]}}
  :wit {:source "https://github.com/WebAssembly/component-model/blob/main/design/mvp/WIT.md"
        :package "kotoba:application@1.0.0"}
  :canonical-abi {:source "https://github.com/WebAssembly/component-model/blob/main/design/mvp/CanonicalABI.md"
                  :string-encoding :utf8
                  :memory :compiler-owned
                  :realloc :compiler-generated
                  :post-return :compiler-generated-when-required}
  :wasi {:default "0.2.11"
         :source "https://github.com/WebAssembly/WASI/releases/tag/v0.2.11"
         :revision "ed73919426173babd88ae145e31deca3d484bbd0"
         :async-profile {:version "0.3.0" :status :deferred
                         :revision "3ee2a590c766594ae44a54730fc74fc27da5c609"
                         :features [:async-func :stream :future]
                         :minimum-wasmtime-major 43}}}
 :types
 {:i64 {:wit :s64}
  :f32 {:wit :f32}
  :f64 {:wit :f64}
  :bool {:wit :bool}
  :string {:wit :string :validation :kotoba-utf8-byte-limit}
  :keyword {:wit :string :validation :kotoba-canonical-keyword}
  :option {:wit :option}
  :result {:wit :result}
  :record {:wit :record :identity :schema-digest-metadata}
  :variant {:wit :variant :identity :schema-digest-metadata}
  :vector {:wit :list :validation :kotoba-item-bound}
  :set {:wit :list :validation :kotoba-bound+canonical-order+unique}
  :map {:wit :list-of-entry-records :validation :kotoba-bound+canonical-order+unique-keys}
  :recursive-schema {:wit nil :disposition :reject-v1}}
 :world
 {:construction :per-application
  :imports :exact-declared-capability-interfaces
  :exports :exact-declared-entry-functions
  :undeclared-import :reject
  :ambient-wasi false}
 :capabilities
 [{:name :http/post :id 4 :interface "http-post" :function "post"
   :kit :http :provider-wasi ["wasi:http/outgoing-handler@0.2.11"]}
  {:name :log/read :id 5 :interface "log" :function "read"
   :kit :log :provider-wasi []}
  {:name :log/append :id 6 :interface "log" :function "append"
   :kit :log :provider-wasi []}
  {:name :clock/now :id 7 :interface "clock" :function "now"
   :kit :clock
   :provider-wasi ["wasi:clocks/wall-clock@0.2.11" "wasi:clocks/monotonic-clock@0.2.11"]}
  {:name :state/transact :id 8 :interface "state" :function "transact"
   :kit :state :provider-wasi []}
  {:name :ui/commit :id 9 :interface "ui" :function "commit"
   :kit :ui :provider-wasi []}
  {:name :ui/next-event :id 10 :interface "ui" :function "next-event"
   :kit :ui :provider-wasi []}
  {:name :llm/generate :id 11 :interface "llm" :function "generate"
   :kit :llm :provider-wasi []}
  {:name :storage/transact :id 12 :interface "storage" :function "transact"
   :kit :storage :provider-wasi []}]
 :provider-authority
 {:rule :kit-declared-only
  :no-inferred-wasi true
  :note "An empty provider-wasi list means a Kotoba-specific host/provider implementation, not ambient authority. Storage does not imply filesystem; LLM does not imply sockets."}
 :limits
 {:transport :canonical-abi
  :semantic-validation [:before-provider :after-provider]
  :wit-bounded-list-feature :not-required}}
