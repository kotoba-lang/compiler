#!/usr/bin/env -S npx --no-install nbb
(ns kotoba-driver
  (:require ["node:child_process" :as child]
            ["node:crypto" :as crypto]
            ["node:fs" :as fs]
            ["node:os" :as os]
            ["node:path" :as path]))

(def usage
  ["usage: kotoba -M compile <file.kotoba|file.cljk|file.cljc> --target wasm32-browser|wasm32-wasi|x86_64-linux|x86_64-macos|x86_64-windows|aarch64-linux|aarch64-macos|aarch64-windows|aarch64-android|aarch64-ios|js|js-browser [--policy policy.edn] --output <file>"
   "       kotoba -M check <file.kotoba|file.cljk|file.cljc> [--policy policy.edn]"
   "       kotoba -M inspect <file.kotoba|file.cljk|file.cljc> [--output interface.edn]"
   "       kotoba -M package-ios program.kexe [--entry main] --output program.S [--manifest-output program.edn]"
   "       kotoba -M sbom <artifact> --output artifact.spdx"
   "       kotoba -M attest-release <artifact> --sbom artifact.spdx --target <target> --key key.edn --not-before <epoch> --expires <epoch> --output release.edn"
   "       kotoba -M verify-release release.edn --artifact <artifact> --sbom artifact.spdx --trust trust.edn --now <epoch>"
   "       kotoba -M coverage <coverage-manifest.edn> --dataset <raw-dataset> [--evidence evidence.edn --trust trust.edn --now <epoch>]"
   "       kotoba -M sign-coverage-evidence <claim.edn> --key <key.edn> --output <evidence.edn>"
   "       kotoba -M keygen --output key.edn"
   "       kotoba -M public-key key.edn --output verification-key.edn"
   "       kotoba -M trust-key verification-key.edn --output trust.edn"
   "       kotoba -M measure-runtime --output runtime.edn --loader-output kotoba-loader"
   "       kotoba -M trust-runtime runtime.edn --trust trust.edn --output pinned-trust.edn"
   "       kotoba -M sign program.kexe --key key.edn --expires <epoch> --output signed.kexe"
   "       kotoba -M verify-signed signed.kexe --trust trust.edn [--now <epoch>]"
   "       kotoba -M run signed.kexe --trust trust.edn --runtime runtime.edn --loader kotoba-loader --policy policy.edn --input input.edn --executor-key key.edn --output receipt.edn"
   "       kotoba -M receipt --signed signed.kexe --trust trust.edn --executor-key key.edn --policy policy.edn --input in.edn --result out.edn ..."
   "       kotoba -M verify-receipt receipt.edn --signed signed.kexe --trust trust.edn --policy policy.edn --input in.edn --result out.edn --now <epoch>"
   "       kotoba -M verify-chain receipts.edn --trust trust.edn"
   "       kotoba -M verify <file>"])

(defn fail! [message code]
  (.error js/console message)
  (.exit js/process code))

;; The wasm32 and ordinary (non-aiueos) native target names
;; `kotoba.compiler.nbb.cli` covers (mirrors its own `targets` table).
;; `x86_64-aiueos-*`/`aarch64-aiueos-*` (ELF64/PE32+ firmware/kernel
;; packaging) stay JVM-only -- see that namespace's own comment for why.
;; Any other `--target` value, or any subcommand besides `compile`/
;; `check`, falls through to the JVM `clojure -M:run` path below
;; unchanged.
(def ^:private nbb-native-targets
  #{"wasm32" "wasm32-browser" "wasm32-wasi" nil
    "x86_64" "x86_64-linux" "x86_64-macos" "x86_64-windows"
    "aarch64" "aarch64-linux" "aarch64-macos" "aarch64-windows"
    "aarch64-android" "aarch64-ios"})

(defn- option [args flag] (second (drop-while #(not= flag %) args)))

(defn- nbb-native-eligible? [sub-args]
  (let [cmd (first sub-args)]
    (or (= cmd "check")
        (and (= cmd "compile") (contains? nbb-native-targets (option sub-args "--target"))))))

;; `kotoba.compiler.nbb.cli` requires `kotoba.compiler.admission`, which in
;; turn requires `kotoba.security.abac`/`kotoba.security.information-flow`
;; from the `io.github.kotoba-lang/security` git dependency pinned in
;; `deps.edn`. nbb has no concept of `deps.edn`/tools.deps -- it only
;; resolves namespaces from directories on its own `--classpath`. `clojure
;; -Spath` is the only thing that (a) fetches that pinned git SHA into
;; `~/.gitlibs` if it isn't already cached there and (b) prints the
;; resulting directories, so it's used here purely as a classpath
;; resolver, not to run any compiler code on the JVM. Its result is cached
;; to a temp file keyed by a hash of `deps.edn`'s bytes so the fast path
;; only pays the JVM-startup + dependency-resolution cost once per distinct
;; `deps.edn` (e.g. once per CI job's checkout), not once per `compile`/
;; `check` call -- callers like `scripts/fuzz-native.cljs` invoke this
;; fast path thousands of times in a loop.
(defn- security-classpath-entry [root]
  (let [deps-edn (.join path root "deps.edn")
        digest (-> (.createHash crypto "sha256")
                   (.update (.readFileSync fs deps-edn))
                   (.digest "hex"))
        cache-file (.join path (.tmpdir os) (str "kotoba-security-classpath-" digest ".txt"))]
    (if (.existsSync fs cache-file)
      (.trim (.readFileSync fs cache-file "utf8"))
      (let [result (.spawnSync child "clojure" (clj->js ["-Spath"])
                               #js {:cwd root :encoding "utf8" :maxBuffer 1048576})]
        (if (and (not (.-error result)) (zero? (or (.-status result) 70)))
          (let [resolved (.trim (.-stdout result))]
            (.writeFileSync fs cache-file resolved)
            resolved)
          "")))))

(let [args (vec *command-line-args*)
      boundary (first args)]
  (cond
    (contains? #{nil "" "-h" "--help"} boundary)
    (doseq [line usage] (println line))

    (contains? #{"-M" "-M:compiler" "-M:compile"} boundary)
    (let [self (.realpathSync fs *file*)
          root (.resolve path (.dirname path self) "..")
          sub-args (subvec args 1)]
      (if (nbb-native-eligible? sub-args)
        ;; Fast path: no `clojure` (JVM) process is spawned at all. A fresh
        ;; nbb process is spawned (not this one) purely so `--classpath`
        ;; can point at `<root>/src` -- `bin/kotoba` itself is invoked via
        ;; its shebang with no classpath flags, so it can't `:require`
        ;; those namespaces directly in its own process. Spawns nbb's own
        ;; `node_modules/nbb/cli.js` directly via `process.execPath`
        ;; (same pattern `scripts/browser-matrix.cljs`'s `nbb!` already
        ;; uses), NOT `npx` -- confirmed live: `spawnSync("npx", ...)`
        ;; fails on Windows CI ("unable to start nbb-native compiler
        ;; runtime") because `npx` resolves to `npx.cmd`, which needs
        ;; shell interpretation `spawnSync` doesn't provide by default;
        ;; `process.execPath` (the current `node`/`node.exe`) is a real,
        ;; directly-executable binary on every platform.
        (let [nbb-cli (.join path root "node_modules" "nbb" "cli.js")
              security-cp (security-classpath-entry root)
              classpath (if (seq security-cp)
                          (str (.join path root "src") (.-delimiter path) security-cp)
                          (.join path root "src"))
              result (.spawnSync child js/process.execPath
                                 (clj->js (into [nbb-cli "--classpath"
                                                 classpath
                                                 (.join path root "src" "kotoba" "compiler" "nbb" "cli.cljs")]
                                                sub-args))
                                 #js {:cwd root :stdio "inherit" :env js/process.env})]
          (when (.-error result)
            (fail! "error: unable to start nbb-native compiler runtime" 70))
          (.exit js/process (or (.-status result) 70)))
        (let [result (.spawnSync child "clojure"
                                 (clj->js (into ["-M:run"] sub-args))
                                 #js {:cwd root :stdio "inherit" :env js/process.env})]
          (when (.-error result)
            (fail! "error: unable to start private compiler runtime" 70))
          (.exit js/process (or (.-status result) 70)))))

    :else
    (fail! "error: compiler commands require the -M execution boundary" 2)))
