#!/usr/bin/env -S npx --no-install nbb
(ns kotoba-driver
  (:require ["node:child_process" :as child]
            ["node:fs" :as fs]
            ["node:path" :as path]))

(def usage
  ["usage: kotoba -M compile <file.kotoba> --target wasm32-browser|wasm32-wasi|x86_64-linux|x86_64-macos|x86_64-windows|aarch64-linux|aarch64-macos|aarch64-windows|aarch64-android|aarch64-ios [--policy policy.edn] --output <file>"
   "       kotoba -M check <file.kotoba> [--policy policy.edn]"
   "       kotoba -M package-ios program.kexe [--entry main] --output program.S [--manifest-output program.edn]"
   "       kotoba -M sbom <artifact> --output artifact.spdx"
   "       kotoba -M attest-release <artifact> --sbom artifact.spdx --target <target> --key key.edn --not-before <epoch> --expires <epoch> --output release.edn"
   "       kotoba -M verify-release release.edn --artifact <artifact> --sbom artifact.spdx --trust trust.edn --now <epoch>"
   "       kotoba -M coverage <coverage-manifest.edn> --dataset <raw-dataset> [--evidence evidence.edn --trust trust.edn --now <epoch>]"
   "       kotoba -M sign-coverage-evidence <claim.edn> --key <key.edn> --output <evidence.edn>"
   "       kotoba -M keygen --output key.edn"
   "       kotoba -M public-key key.edn --output verification-key.edn"
   "       kotoba -M trust-key verification-key.edn --output trust.edn"
   "       kotoba -M measure-runtime --output runtime.edn --loader-output kotoba-loader"
   "       kotoba -M trust-runtime runtime.edn --trust trust.edn --output pinned-trust.edn"
   "       kotoba -M sign program.kexe --key key.edn --expires <epoch> --output signed.kexe"
   "       kotoba -M verify-signed signed.kexe --trust trust.edn [--now <epoch>]"
   "       kotoba -M run signed.kexe --trust trust.edn --runtime runtime.edn --loader kotoba-loader --policy policy.edn --input input.edn --executor-key key.edn --output receipt.edn"
   "       kotoba -M receipt --signed signed.kexe --trust trust.edn --executor-key key.edn --policy policy.edn --input in.edn --result out.edn ..."
   "       kotoba -M verify-receipt receipt.edn --signed signed.kexe --trust trust.edn --policy policy.edn --input in.edn --result out.edn --now <epoch>"
   "       kotoba -M verify-chain receipts.edn --trust trust.edn"
   "       kotoba -M verify <file>"])

(defn fail! [message code]
  (.error js/console message)
  (.exit js/process code))

;; The three wasm32 target names `kotoba.compiler.nbb.cli` covers (mirrors
;; its own `targets` table). Any other `--target` value, or any subcommand
;; besides `compile`/`check`, falls through to the JVM `clojure -M:run`
;; path below unchanged.
(def ^:private nbb-native-targets #{"wasm32" "wasm32-browser" "wasm32-wasi" nil})

(defn- option [args flag] (second (drop-while #(not= flag %) args)))

(defn- nbb-native-eligible? [sub-args]
  (let [cmd (first sub-args)]
    (or (= cmd "check")
        (and (= cmd "compile") (contains? nbb-native-targets (option sub-args "--target"))))))

(let [args (vec *command-line-args*)
      boundary (first args)]
  (cond
    (contains? #{nil "" "-h" "--help"} boundary)
    (doseq [line usage] (println line))

    (contains? #{"-M" "-M:compiler" "-M:compile"} boundary)
    (let [self (.realpathSync fs *file*)
          root (.resolve path (.dirname path self) "..")
          sub-args (subvec args 1)]
      (if (nbb-native-eligible? sub-args)
        ;; Fast path: no `clojure` (JVM) process is spawned at all. A fresh
        ;; nbb process is spawned (not this one) purely so `--classpath`
        ;; can point at `<root>/src` -- `bin/kotoba` itself is invoked via
        ;; its shebang with no classpath flags, so it can't `:require`
        ;; those namespaces directly in its own process.
        (let [result (.spawnSync child "npx"
                                 (clj->js (into ["--no-install" "nbb" "--classpath"
                                                 (.join path root "src")
                                                 (.join path root "src" "kotoba" "compiler" "nbb" "cli.cljs")]
                                                sub-args))
                                 #js {:cwd root :stdio "inherit" :env js/process.env})]
          (when (.-error result)
            (fail! "error: unable to start nbb-native compiler runtime" 70))
          (.exit js/process (or (.-status result) 70)))
        (let [result (.spawnSync child "clojure"
                                 (clj->js (into ["-M:run"] sub-args))
                                 #js {:cwd root :stdio "inherit" :env js/process.env})]
          (when (.-error result)
            (fail! "error: unable to start private compiler runtime" 70))
          (.exit js/process (or (.-status result) 70)))))

    :else
    (fail! "error: compiler commands require the -M execution boundary" 2)))
