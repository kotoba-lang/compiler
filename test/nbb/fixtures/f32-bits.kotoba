(ns f32-bits (:export [main bits from-bits rounded widen add to-f32 to-i64]))
(defn main [] 0)
(defn bits [value :f32] :i64 (f32-to-bits value))
(defn from-bits [value :i64] :f32 (f32-from-bits value))
(defn rounded [value :f64] :f32 (f64-to-f32-rounded value))
(defn widen [value :f32] :f64 (f32-to-f64-exact value))
(defn add [left :f32 right :f32] :f32 (f32-add left right))
(defn to-f32 [value :i64] :f32 (i64-to-f32-checked value))
(defn to-i64 [value :f32] :i64 (f32-to-i64-checked value))
