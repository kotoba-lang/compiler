(ns f32-bits (:export [main bits from-bits rounded widen add to-f32 to-i64 sqrt minimum maximum sin cos wide-sin wide-cos exp log atan2]))
(defn main [] 0)
(defn bits [value :f32] :i64 (f32-to-bits value))
(defn from-bits [value :i64] :f32 (f32-from-bits value))
(defn rounded [value :f64] :f32 (f64-to-f32-rounded value))
(defn widen [value :f32] :f64 (f32-to-f64-exact value))
(defn add [left :f32 right :f32] :f32 (f32-add left right))
(defn to-f32 [value :i64] :f32 (i64-to-f32-checked value))
(defn to-i64 [value :f32] :i64 (f32-to-i64-checked value))
(defn sqrt [value :f32] :f32 (f32-sqrt value))
(defn minimum [left :f32 right :f32] :f32 (f32-min left right))
(defn maximum [left :f32 right :f32] :f32 (f32-max left right))
(defn sin [value :f64] :f64 (f64-sin-quarter-turn value))
(defn cos [value :f64] :f64 (f64-cos-quarter-turn value))
(defn wide-sin [value :f64] :f64 (f64-sin-bounded value))
(defn wide-cos [value :f64] :f64 (f64-cos-bounded value))
(defn exp [value :f64] :f64 (f64-exp-near-zero value))
(defn log [value :f64] :f64 (f64-log-near-one value))
(defn atan2 [y :f64 x :f64] :f64 (f64-atan2-bounded y x))
